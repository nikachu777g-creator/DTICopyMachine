local function getItemToggles(char, itemName)
	if not char then return nil end
	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return nil end
	local item = equipped:FindFirstChild(itemName)
	if not item then return nil end
	local customizationData = WaitForChildSafe(item, "CustomizationData", 2)
	if not customizationData then return nil end
	local mainToggle = WaitForChildSafe(customizationData, "Toggle", 2)
	if not mainToggle then return nil end
	local subToggles = WaitForChildSafe(customizationData, "SubToggles", 2)
	local switchToggles = WaitForChildSafe(customizationData, "SwitchToggles", 2)

	local toggleInfo = {}
	toggleInfo["Main"] = mainToggle.Value
	local stInfo = {}
	if subToggles then
		for _, stVal in subToggles:GetChildren() do
			if stVal:IsA("StringValue") then
				stInfo[stVal.Name] = stVal.Value
			end
		end
	end
	toggleInfo["Subs"] = stInfo

	local swInfo = {}
	if switchToggles then
		local success, togglesModule = pcall(function()
			return require(game.ReplicatedStorage.Content.Toggles)
		end)
		if success and togglesModule then
			local itemToggles = togglesModule[itemName]
			if itemToggles and itemToggles.Toggles ~= nil then
				local swapsInfo = itemToggles.Toggles[tonumber(mainToggle.Value)] and itemToggles.Toggles[tonumber(mainToggle.Value)].SwapToggles
				if type(swapsInfo) == "table" then
					for _, stVal in ipairs(switchToggles:GetChildren()) do
						if stVal:IsA("StringValue") then
							local stIndex = tonumber(stVal.Name)
							if stIndex and swapsInfo[stIndex] then
								table.insert(swInfo, {
									ofType = swapsInfo[stIndex].displayName,
									index = tonumber(stVal.Value)
								})
							end
						end
					end
				end
			end
		end
	end
	toggleInfo["Switch"] = swInfo
	return toggleInfo
end

local function getNailsInfo(char)
	if not char then return nil end
	local def = WaitForChildSafe(char, "DefaultAccessories", 2)
	if not def then return nil end
	local nailsFolder = WaitForChildSafe(def, "Nails", 2)
	if not nailsFolder then return nil end
	local nailsPart = nailsFolder:FindFirstChildOfClass("MeshPart")
	if not nailsPart then return nil end

	local nailShape
	for shapeName, shapeMesh in pairs(nailMeshes) do
		if shapeMesh == nailsPart.MeshId then
			nailShape = shapeName
			break
		end
	end
	local nailColor = nailsPart.Color
	local nailPattern = nailsPart.TextureID
	if nailPattern == "" then nailPattern = nil end

	local nailMaterial = ""
	local customizationData = nailsFolder:FindFirstChild("CustomizationData")
	if customizationData then
		local colors = customizationData:FindFirstChild("Colors")
		if colors then
			local colorOne = colors:FindFirstChild("1")
			if colorOne then
				nailMaterial = colorOne:GetAttribute("Material") or ""
			end
		end
	end
	return {Shape = nailShape, Color = nailColor, Pattern = nailPattern, Material = nailMaterial}
end

local function getClearFace()
	local success, classicM = pcall(function()
		return require(game.ReplicatedStorage:WaitForChild("Content"):WaitForChild("ClassicMakeup"))
	end)
	if success and classicM then
		return #classicM
	end
	return 301 -- запасное значение
end

local function getClassicIn(char)
	if not char then return getClearFace(), "Light" end
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return getClearFace(), "Light" end
	local face = head:FindFirstChild("face")
	if not face or not face:IsA("Decal") then return getClearFace(), "Light" end
	local tex = face.Texture

	local success, classicM = pcall(function()
		return require(game.ReplicatedStorage:WaitForChild("Content"):WaitForChild("ClassicMakeup"))
	end)
	if success and classicM then
		for i, faceInfo in ipairs(classicM) do
			local textures = faceInfo[1]
			if type(textures) == "table" then
				if textures[1] == tex then return i, "Light"
				elseif textures[2] == tex then return i, "Dark" end
			else
				if textures == tex then return i, "Light" end
			end
		end
	end
	return getClearFace(), "Light"
end

local function getMakeup(char)
	if not char then return end
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return end
	local custom = false
	for _, dec in head:GetChildren() do
		if dec:IsA("Decal") and dec.Name ~= "face" then
			custom = true
			break
		end
	end
	if custom then
		getCMPreset(char)
	else
		local inx, tone = getClassicIn(char)
		local classicRemote = WaitForChildSafe(RemoteEvents, "ClassicMakeup", 5)
		if classicRemote then
			classicRemote:FireServer(inx, tone)
		end
	end
end

-- Основные remote события
local equipRemote = WaitForChildSafe(RemoteEvents, "EquipItem", 5)
local unEquipRemote = WaitForChildSafe(RemoteEvents, "UnequipItem", 5)
local colorRemote = WaitForChildSafe(RemoteEvents, "ColorAccessory", 5)
local skinRemote = WaitForChildSafe(RemoteEvents, "ChangeSkintone", 5)
local matRemote = WaitForChildSafe(RemoteEvents, "MaterialAccessory", 5)
local adjustRemote = WaitForChildSafe(RemoteEvents, "AdjustAccessory", 5)
local vitilgoRemote = WaitForChildSafe(RemoteEvents, "VitiligoSkin", 5)
local dressUpToggle = WaitForChildSafe(RemoteEvents, "DressUpToggle", 5)
local changeGenderRemote = WaitForChildSafe(RemoteEvents, "ChangeGender", 5)

local function getOutfit(char)
	if not char then return end
	local gender = getGender(char)
	if gender and changeGenderRemote then
		changeGenderRemote:FireServer(gender)
	end

	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return end

	for _, item in equipped:GetChildren() do
		if equipRemote then equipRemote:FireServer(item.Name) end
		
		local toggleInfo = getItemToggles(char, item.Name)
		if toggleInfo and dressUpToggle then
			local main = toggleInfo.Main
			local subs = toggleInfo.Subs
			local switch = toggleInfo.Switch or {}
			dressUpToggle:FireServer(item.Name, main, subs, nil, nil, switch)
		end

		local adjustments = getItemAdjustments(char, item.Name)
		if adjustments and adjustRemote then
			local positionInfo = adjustments.Position
			local rotationInfo = adjustments.Rotation
			local scale = adjustments.Scale
			for axis, value in pairs(positionInfo) do
				if value ~= 0 then
					adjustRemote:FireServer(item.Name, "Position", axis, value)
				end
			end
			for axis, value in pairs(rotationInfo) do
				if value ~= 0 then
					adjustRemote:FireServer(item.Name, "Rotation", axis, value)
				end
			end
			if scale ~= 1 then
				adjustRemote:FireServer(item.Name, "Scale", "_", scale)
			end
		end

		local itemInfo = getItemInfo(char, item.Name)
		if itemInfo then
			for _, partData in ipairs(itemInfo) do
				if colorRemote then
					colorRemote:FireServer(item.Name, partData.Index, partData.Color)
					if partData.Pattern then
						colorRemote:FireServer(item.Name, partData.Index, partData.Pattern)
					end
				end
				if partData.Material and matRemote then
					matRemote:FireServer(item.Name, partData.Index, partData.Material)
				end
			end
		end
	end

	local nailsInfo = getNailsInfo(char)
	if nailsInfo then
		if nailsInfo.Shape and nailEvent then
			nailEvent:FireServer(nailsInfo.Shape)
		end
		if nailsInfo.Color and colorRemote then
			colorRemote:FireServer("Nails", "1", nailsInfo.Color)
		end
		if nailsInfo.Pattern and colorRemote then
			colorRemote:FireServer("Nails", "1", nailsInfo.Pattern)
		end
		if nailsInfo.Material and matRemote then
			matRemote:FireServer("Nails", "1", nailsInfo.Material)
		end
	end

	local head = WaitForChildSafe(char, "Head", 2)
	if head and skinRemote then
		skinRemote:FireServer(head.Color)
	end

	local vitiligo = char:GetAttribute("Vitiligo") or "Off"
	if vitiligo and vitilgoRemote then
		vitilgoRemote:FireServer(tostring(vitiligo))
	end
end

local function clearOutfit()
	local char = LocalPlayer.Character
	if not char then return end
	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return end
	for _, v in equipped:GetChildren() do
		if unEquipRemote then
			unEquipRemote:FireServer(v.Name)
		end
	end
end

local function WearOutfit(Outfit)
	if not Outfit then return end
	local success, err = pcall(function()
		clearOutfit()
		getOutfit(Outfit)

		local classicRemote = WaitForChildSafe(RemoteEvents, "ClassicMakeup", 5)
		if classicRemote then
			classicRemote:FireServer(301, "Light")
		end
		getMakeup(Outfit)
	end)
	if not success then
		warn("WearOutfit error: " .. tostring(err))
	end
end

