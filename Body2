-- Безопасное ожидание дочернего объекта с таймаутом
local function WaitForChildSafe(parent, childName, timeout)
	timeout = timeout or 5
	local start = tick()
	while tick() - start < timeout do
		local child = parent:FindFirstChild(childName)
		if child then
			return child
		end
		task.wait(0.1)
	end
	warn("WaitForChildSafe: timeout waiting for " .. childName .. " in " .. parent.Name)
	return nil
end

