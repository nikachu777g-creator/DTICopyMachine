-- Создание элемента GUI с проверками
function CreateAGuiPart(ClassName, Parent, Properties)
	if not Parent then
		warn("CreateAGuiPart: Parent is nil, cannot create " .. ClassName)
		return nil
	end
	local GuiPart = Instance.new(ClassName)
	if Properties then
		for PropertyName, PropertyValue in pairs(Properties) do
			pcall(function()
				GuiPart[PropertyName] = PropertyValue
			end)
		end
	end
	GuiPart.Parent = Parent
	return GuiPart
end

