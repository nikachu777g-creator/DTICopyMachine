function WearOutfitLegacy(Outfit)
	if not Outfit then return end
	local char = LocalPlayer.Character
	if not char then return end
	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return end

	for _, Cloth in equipped:GetChildren() do
		if unEquipRemote then unEquipRemote:FireServer(Cloth.Name) end
	end

	local outfitEquipped = WaitForChildSafe(Outfit, "EquippedAccessories", 2)
	if not outfitEquipped then return end
	for _, Cloth in outfitEquipped:GetChildren() do
		if equipRemote then equipRemote:FireServer(Cloth.Name) end
		local customizationData = WaitForChildSafe(Cloth, "CustomizationData", 2)
		if customizationData then
			local colors = WaitForChildSafe(customizationData, "Colors", 2)
			if colors then
				for _, Color in colors:GetChildren() do
					if colorRemote then
						colorRemote:FireServer(Cloth.Name, Color.Name, Color:GetAttribute("Color"))
						colorRemote:FireServer(Cloth.Name, Color.Name, Color:GetAttribute("Pattern"))
					end
				end
			end
			local subToggles = WaitForChildSafe(customizationData, "SubToggles", 2)
			local mainToggle = WaitForChildSafe(customizationData, "Toggle", 2)
			if subToggles and mainToggle and dressUpToggle then
				local SubToggles = {}
				for _, SubToggle in subToggles:GetChildren() do
					SubToggles[SubToggle.Name] = SubToggle.Value
				end
				dressUpToggle:FireServer(Cloth.Name, mainToggle.Value, SubToggles)
			end
		end
	end

	local head = WaitForChildSafe(Outfit, "Head", 2)
	if head and skinRemote then
		skinRemote:FireServer(head.Color)
	end
end

-- Загрузка и выгрузка аутфитов
local function LoadOutfits(Player)
	if not Player then return end
	local outfitFolder = WaitForChildSafe(ReplicatedStorage, "OutfitReplicationFolder", 5)
	if not outfitFolder then return end

	for _, Outfit in outfitFolder:GetChildren() do
		if Outfit:IsA("Model") and string.find(Outfit.Name, tostring(Player.UserId)) then
			local OutfitModel = Outfit:Clone()
			local OutfitButton = CreateAGuiPart("TextButton", OutfitList, {
				Size = UDim2.new(0.321,0,0.309,0),
				TextTransparency = 1,
				BackgroundColor3 = Color3.new(0.823529, 1, 0.592157),
				BorderSizePixel = 0
			})
			if not OutfitButton then continue end
			CreateAGuiPart("UIAspectRatioConstraint", OutfitButton)

			local ViewportFrame = CreateAGuiPart("ViewportFrame", OutfitButton, {
				Size = UDim2.new(1,0,1,0),
				BackgroundTransparency = 1
			})
			if ViewportFrame then
				local Camera = CreateAGuiPart("Camera", ViewportFrame, {
					CFrame = CFrame.new(0, 0.7, -3) * CFrame.Angles(0, math.rad(180), 0)
				})
				if Camera then
					ViewportFrame.CurrentCamera = Camera
				end
			end

			local IDStart, IDEnd = string.find(Outfit.Name, tostring(Player.UserId))
			local Name = string.sub(Outfit.Name, 1, IDStart-1)

			local OutfitName = CreateAGuiPart("TextLabel", OutfitButton, {
				Position = UDim2.new(0,0,0.793,0),
				Size = UDim2.new(0.996,0,0.202,0),
				BackgroundTransparency = 1,
				Text = Name,
				TextScaled = true,
				TextColor3 = Color3.new(1, 1, 1)
			})
			if OutfitName then
				CreateAGuiPart("UIStroke", OutfitName, {
					Color = Color3.new(0, 0, 0),
					Thickness = 1
				})
			end

			local WorldModel = CreateAGuiPart("WorldModel", ViewportFrame)
			if WorldModel then
				OutfitModel.Parent = WorldModel
				OutfitModel:PivotTo(CFrame.new(0, 0, 0))
			end

			-- Debounce для кнопки
			local debounce = false
			OutfitButton.MouseButton1Click:Connect(function()
				if debounce then return end
				debounce = true
				task.delay(1, function() debounce = false end)
				WearOutfit(Outfit)
			end)
		end
		task.wait() -- небольшая задержка, чтобы не нагружать поток при большом количестве аутфитов
	end
end

function UnloadOutfits()
	if not OutfitList then return end
	for _, child in OutfitList:GetChildren() do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end
end

-- Кнопки игроков
function AddPlayerButton(Player)
	if not Player then return end
	local PlayerButton = CreateAGuiPart("TextButton", PlayerList, {
		Size = UDim2.new(0.333,0,0.223,0),
		Text = Player.Name,
		TextScaled = true,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0
	})
	if not PlayerButton then return end
	PlayerButton.Name = Player.Name

	local debounce = false
	PlayerButton.MouseButton1Click:Connect(function()
		if debounce then return end
		debounce = true
		task.delay(0.5, function() debounce = false end)
		for _, btn in PlayerList:GetChildren() do
			if btn:IsA("TextButton") then
				btn.BackgroundColor3 = Color3.new(1, 1, 1)
			end
		end
		PlayerButton.BackgroundColor3 = Color3.new(0.823529, 1, 0.592157)
		UnloadOutfits()
		LoadOutfits(Player)
	end)
end

for _, Player in game.Players:GetChildren() do
	AddPlayerButton(Player)
end

game.Players.PlayerAdded:Connect(function(Player)
	AddPlayerButton(Player)
end)

game.Players.PlayerRemoving:Connect(function(Player)
	if not PlayerList then return end
	for _, btn in PlayerList:GetChildren() do
		if btn.Name == Player.Name then
			btn:Destroy()
		end
	end
end)
