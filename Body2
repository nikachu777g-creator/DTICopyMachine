-- Вспомогательные функции с проверками
local function getDecalIn(char, decalName)
	if not char then return nil end
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return nil end
	local decal = head:FindFirstChild(decalName)
	if not decal or not decal:IsA("Decal") then return nil end
	local index = decal:GetAttribute("Index") or nil
	local color = decal.Color3 or Color3.fromRGB(255, 255, 255)
	return index, color
end

local function getColorKey(char, decalName)
	if not char then return nil end
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return nil end
	local decal = head:FindFirstChild(decalName)
	if not decal or not decal:IsA("Decal") then return nil end
	return decal:GetAttribute("ColorKey") or nil
end

local function getPieceIndexes(char)
	local tbl = {}
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return tbl end
	for _, decal in pairs(head:GetChildren()) do
		if decal:IsA("Decal") then
			local name = decal.Name
			if name ~= "face" then
				local index, color = getDecalIn(char, name)
				if index then
					tbl[name] = {
						Index = index,
						Color = color,
						Key = getColorKey(char, name),
						Feature = decal:GetAttribute("Feature")
					}
				end
			end
		end
	end
	return tbl
end

local function getOpacities(char)
	local tbl = {}
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return tbl end
	for _, decal in pairs(head:GetChildren()) do
		if decal:IsA("Decal") then
			local name = decal.Name
			if name ~= "face" then
				local _, color = getDecalIn(char, name)
				if color then
					local decalObj = head:FindFirstChild(name)
					if not decalObj or not decalObj:IsA("Decal") then continue end
					local transparency = decalObj.Transparency
					if transparency == 0 then continue end
					local key = getColorKey(char, name)
					if not key then continue end
					local data = {transparency, key}
					if decalObj:GetAttribute("Feature") then
						data[3] = decalObj:GetAttribute("Feature")
					end
					tbl[name] = data
				end
			end
		end
	end
	return tbl
end

local function getPieceColors(char)
	local tbl = {}
	local head = WaitForChildSafe(char, "Head", 2)
	if not head then return tbl end
	for _, decal in pairs(head:GetChildren()) do
		if decal:IsA("Decal") then
			local name = decal.Name
			if name ~= "face" then
				local feature = decal:GetAttribute("Feature")
				if not feature then continue end
				local _, color = getDecalIn(char, name)
				if color then
					local makeupIn, _ = getDecalIn(char, name)
					local key = getColorKey(char, name)
					if not key then continue end
					tbl[name] = {color, makeupIn, key, feature}
				end
			end
		end
	end
	return tbl
end

-- Remote события для макияжа
local CMWear = WaitForChildSafe(RemoteEvents, "CustomMakeup", 5)
local CMcolor = WaitForChildSafe(RemoteEvents, "ApplyMakeupColor", 5)
local CMopacity = WaitForChildSafe(RemoteEvents, "MakeupOpacity", 5)

local function getCMPreset(char)
	if not char then return end
	local pieces = getPieceIndexes(char)
	local pieceColors = getPieceColors(char)
	local opacities = getOpacities(char)

	for pieceName, data in pairs(pieces) do
		if data and data.Index and data.Feature then
			local cleanName = data["Feature"]:gsub("%d+", "")
			local pieceIndex = tonumber(string.gsub(data["Feature"], "%D", ""))
			if cleanName == "Touches" then
				if CMWear then CMWear:FireServer(cleanName, data.Index, pieceIndex) end
			else
				if CMWear then CMWear:FireServer(cleanName, data.Index, false) end
			end
		end
	end

	for pieceName, colorData in pairs(pieceColors) do
		local color = colorData[1]
		local makeupIndex = colorData[2]
		local pieceIndex = colorData[3]
		local cleanName = colorData[4]:gsub("%d+", "")
		local touchIndex = tonumber(string.gsub(colorData[4], "%D", ""))
		if pieceIndex then
			if cleanName == "Touches" then
				if CMcolor then CMcolor:FireServer(cleanName, makeupIndex, touchIndex, pieceIndex, color) end
			else
				if CMcolor then CMcolor:FireServer(cleanName, makeupIndex, false, pieceIndex, color) end
			end
		end
	end

	for pieceName, opacity in pairs(opacities) do
		local transparency = opacity[1]
		local pieceIndex = opacity[2]
		local feature = opacity[3]
		if feature then
			local cleanName = feature:gsub("%d+", "")
			local touchIndex = tonumber(string.gsub(feature, "%D", ""))
			if cleanName == "Touches" then
				if CMopacity then CMopacity:FireServer(cleanName, pieceIndex, touchIndex, transparency) end
			else
				if CMopacity then CMopacity:FireServer(cleanName, pieceIndex, false, transparency) end
			end
		end
	end
end

-- Функции для работы с аксессуарами
local function getItemInfo(char, itemName)
	if not char then return nil end
	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return nil end
	local item = equipped:FindFirstChild(itemName)
	if not item then return nil end
	local customizationData = WaitForChildSafe(item, "CustomizationData", 2)
	if not customizationData then return nil end
	local colors = WaitForChildSafe(customizationData, "Colors", 2)
	if not colors then return nil end
	local itemInfo = {}
	for _, v in colors:GetChildren() do
		if v:IsA("Configuration") then
			local partIndex = v.Name
			local partColor = v:GetAttribute("Color")
			local partPattern = v:GetAttribute("Pattern") or nil
			local partMaterial = v:GetAttribute("Material") or nil
			if partPattern == "" then partPattern = nil end
			if partMaterial == "" then partMaterial = nil end
			table.insert(itemInfo, {Index = partIndex, Color = partColor, Pattern = partPattern, Material = partMaterial})
		end
	end
	return itemInfo
end

local function getItemAdjustments(char, itemName)
	if not char then return nil end
	local equipped = WaitForChildSafe(char, "EquippedAccessories", 2)
	if not equipped then return nil end
	local item = equipped:FindFirstChild(itemName)
	if not item then return nil end
	local customizationData = WaitForChildSafe(item, "CustomizationData", 2)
	if not customizationData then return nil end
	local position = WaitForChildSafe(customizationData, "Position", 2)
	local rotation = WaitForChildSafe(customizationData, "Rotation", 2)
	local scale = WaitForChildSafe(customizationData, "Scale", 2)
	if not (position and rotation and scale) then return nil end
	local posX = WaitForChildSafe(position, "X", 1)
	local posY = WaitForChildSafe(position, "Y", 1)
	local posZ = WaitForChildSafe(position, "Z", 1)
	local rotX = WaitForChildSafe(rotation, "X", 1)
	local rotY = WaitForChildSafe(rotation, "Y", 1)
	local rotZ = WaitForChildSafe(rotation, "Z", 1)
	local scaleVal = WaitForChildSafe(scale, "Scale", 1)
	if not (posX and posY and posZ and rotX and rotY and rotZ and scaleVal) then return nil end
	return {
		Position = {X = posX.Value, Y = posY.Value, Z = posZ.Value},
		Rotation = {X = rotX.Value, Y = rotY.Value, Z = rotZ.Value},
		Scale = scaleVal.Value
	}
end

