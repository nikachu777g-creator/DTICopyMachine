	AddPlayerButton(Player)
end)

game.Players.PlayerRemoving:Connect(function(Player)
	for _, PlayerButton in PlayerList:GetChildren() do
		if PlayerButton.Name == Player.Name then
			PlayerButton:Destroy()
		end
	end
end)
