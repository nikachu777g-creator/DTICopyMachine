function WearOutfitLegacy(Outfit)
	for _, Cloth in LocalPlayer.Character.EquippedAccessories:GetChildren() do
		UnequipItem:FireServer(Cloth.Name)
	end
	
	for _, Cloth in Outfit.EquippedAccessories:GetChildren() do
		EquipItem:fireServer(Cloth.Name)
		for _, Color in Cloth.CustomizationData.Colors:GetChildren() do
			ColorAccessory:FireServer(Cloth.Name, Color.Name, Color:GetAttribute("Color"))
			ColorAccessory:FireServer(Cloth.Name, Color.Name, Color:GetAttribute("Pattern"))
		end
		local SubToggles = {}
		for _, SubToggle in Cloth.CustomizationData.SubToggles:GetChildren() do
			SubToggles[SubToggle.Name] = SubToggle.Value
		end
		DressUpToggle:FireServer(Cloth.Name, Cloth.CustomizationData.Toggle.Value, SubToggles)
	end

	ChangeSkintone:FireServer(Outfit.Head.Color)
end

function LoadOutfits(Player)
	for _, Outfit in game:GetService("ReplicatedStorage"):WaitForChild("OutfitReplicationFolder"):GetChildren() do
		local IsContainsPlayerID = string.find(Outfit.Name, Player.UserId)
		if IsContainsPlayerID ~= nil then
			local OutfitModel = Outfit:Clone()
			local OutfitButton = CreateAGuiPart("TextButton", OutfitList, {Size = UDim2.new(0.321,0,0.309,0), TextTransparency = 1, BackgroundColor3 = Color3.new(0.823529, 1, 0.592157), BorderSizePixel = 0})
			CreateAGuiPart("UIAspectRatioConstraint", OutfitButton)
			
			local ViewportFrame = CreateAGuiPart("ViewportFrame", OutfitButton, {Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1})
			local Camera = CreateAGuiPart("Camera", ViewportFrame, {CFrame = CFrame.new(0, 0.7, -3) * CFrame.Angles(0,math.rad(180),0)})
			ViewportFrame.CurrentCamera = Camera
			
			local IDStart, IDEnd = string.find(Outfit.Name, Player.UserId)
			local Name = string.sub(Outfit.Name, 1, IDStart-1)
			
			local OutfitName = CreateAGuiPart("TextLabel", OutfitButton, {Position = UDim2.new(0,0,0.793,0), Size = UDim2.new(0.996,0,0.202,0), BackgroundTransparency = 1, Text = Name, TextScaled = true, TextColor3 = Color3.new(1, 1, 1)})
			CreateAGuiPart("UIStroke", OutfitName, {Color = Color3.new(0, 0, 0), Thickness = 1})
			
			local WorldModel = CreateAGuiPart("WorldModel", ViewportFrame)
			
			OutfitModel.Parent = WorldModel
			Outfit:PivotTo(CFrame.new(0, 0, 0))
			
			OutfitButton.MouseButton1Click:Connect(function()
				WearOutfit(Outfit)
			end)
		end
	end
end

function UnloadOutfits()
	for _, Outfit in OutfitList:GetChildren() do
